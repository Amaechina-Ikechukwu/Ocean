# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase client config. All NEXT_PUBLIC_* vars are inlined into the
# browser bundle at build time — only put values here that are safe to ship
# to the client.
NEXT_PUBLIC_PROJECTID=
NEXT_PUBLIC_APPID=
NEXT_PUBLIC_API_KEY=
NEXT_PUBLIC_AUTH_DOMAIN=
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=
NEXT_PUBLIC_STORAGE_BUCKET=
NEXT_PUBLIC_MESSAGING_SENDER_ID=
