{
  "entities": {
    "workspace": {
      "title": "Workspace",
      "description": "User's organizational space",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" },
        "type": { "type": "string", "enum": ["blog", "work"] }
      },
      "required": ["name", "ownerId", "createdAt", "type"]
    },
    "page": {
      "title": "Page",
      "description": "A page/document in a workspace",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "parentId": { "type": "string" },
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "coverImage": { "type": "string" },
        "order": { "type": "string" },
        "timestamp": { "type": "number" },
        "deleted": { "type": "boolean" },
        "published": { "type": "boolean" },
        "slug": { "type": "string" },
        "publishedAt": { "type": "number" },
        "seo": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "ogImage": { "type": "string" }
          }
        },
        "ownerId": { "type": "string" }
      },
      "required": ["workspaceId", "title", "order", "timestamp", "deleted", "ownerId"]
    },
    "block": {
      "title": "Block",
      "description": "A content block on a page",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "order": { "type": "string" },
        "parentId": { "type": "string" },
        "content": { "type": "string" },
        "attrs": { "type": "object" },
        "ownerId": { "type": "string" }
      },
      "required": ["type", "order", "content", "ownerId"]
    },
    "publicPage": {
      "title": "PublicPage",
      "description": "Slug -> page resolution for anonymous renderer. Maintained by Cloud Function.",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "pageId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["workspaceId", "pageId", "ownerId"]
    }
  },
  "firestore": {
    "/workspaces/{workspaceId}": {
      "schema": { "$ref": "#/entities/workspace" },
      "description": "Workspaces root collection"
    },
    "/workspaces/{workspaceId}/pages/{pageId}": {
      "schema": { "$ref": "#/entities/page" },
      "description": "Pages in a workspace"
    },
    "/workspaces/{workspaceId}/pages/{pageId}/blocks/{blockId}": {
      "schema": { "$ref": "#/entities/block" },
      "description": "Blocks in a page"
    },
    "/publicPages/{slug}": {
      "schema": { "$ref": "#/entities/publicPage" },
      "description": "Slug mirror for anonymous public page rendering (server-maintained)"
    }
  }
}
